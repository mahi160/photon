{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photon",
  "version": "1.5.1",
  "identifier": "io.github.mahi160.Photon",
  "build": {
    "beforeDevCommand": "pnpm exec vite --config vite.tauri.config.ts",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm exec vite build --config vite.tauri.config.ts",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Photon",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#0e0e10",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
